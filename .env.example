# ─── ConceptManager — Variables d'environnement ───────────────────────────────
# Copier ce fichier en .env et renseigner les valeurs réelles.
# Ne jamais commiter .env dans Git.
#
# Voir docs/DEPLOYMENT.md pour le guide de déploiement complet.
# ──────────────────────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════════════════════════
# VARIABLES DE DÉPLOIEMENT (instance-specific)
# ═══════════════════════════════════════════════════════════════════════════════
# Identifient cette instance et configurent son intégration à l'infra Acreed.
# Doivent être différentes pour chaque instance (demo, client X, client Y).

# Identifiant kebab-case de l'instance (sera préfixé par cm- partout).
# Exemples : demo, js-concept, asp-signalisation, thermipro
PROJECT_SLUG=demo

# Environnement de déploiement : dev (dev/démo) ou prod (client payant).
DEPLOY_ENV=dev

# Réseau Docker externe (créé en amont via `docker network create`).
# - acreed-dev pour DEPLOY_ENV=dev
# - acreed-prod pour DEPLOY_ENV=prod
# - acreed-tools pour les outils internes (cas particulier)
ACREED_NETWORK=acreed-dev

# Ports loopback (host → container). DOIVENT être uniques par instance sur
# la même machine (sinon conflit). Tous bindés sur 127.0.0.1 (UFW).
# Plages conventionnelles Acreed :
#   - dev/démo  : 8090-8099 / 3090-3099 / 5440-5449 / 9090-9099
#   - prod      : 8100-8199 / 3100-3199 / 5440-5499 / 9100-9199
POSTGRES_HOST_PORT=5445
API_HOST_PORT=3095
FRONTEND_HOST_PORT=8095
MINIO_HOST_PORT=9095
MINIO_CONSOLE_HOST_PORT=9096


# ═══════════════════════════════════════════════════════════════════════════════
# VARIABLES APPLICATIVES (secrets)
# ═══════════════════════════════════════════════════════════════════════════════
# À régénérer pour chaque instance — JAMAIS réutiliser entre instances.
# Sauvegarder dans un password manager (ex: Bitwarden) après génération.

NODE_ENV=production

# PostgreSQL — POSTGRES_DB et POSTGRES_USER peuvent rester par défaut,
# POSTGRES_PASSWORD doit être unique et fort (min 32 chars).
POSTGRES_DB=concept_manager
POSTGRES_USER=concept
POSTGRES_PASSWORD=CHANGER_MOI_mot_de_passe_fort_32chars

# JWT — générer avec : openssl rand -base64 48
JWT_SECRET=CHANGER_MOI_generer_avec_openssl_rand_base64_48
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=7

# Sceau d'intégrité des factures (HMAC-SHA256) — obligatoire en prod.
# Générer avec : openssl rand -base64 48.
# /!\ NE PAS rotater seul : ré-sceller toutes les factures existantes sinon
# elles deviennent juridiquement invalides (Factur-X).
INVOICE_HMAC_KEY=CHANGER_MOI_generer_avec_openssl_rand_base64_48

# CORS — comma-separated list of allowed origins
# Pour la démo : https://conceptmanager.acreediasolutions.com
# Pour client X : https://<slug>.acreediasolutions.com
CORS_ORIGINS=https://app.example.com

# MinIO
MINIO_ROOT_USER=CHANGER_MOI_utilisateur_minio
MINIO_ROOT_PASSWORD=CHANGER_MOI_mot_de_passe_minio_fort
MINIO_BUCKET=concept-files

# Anthropic (optionnel — features IA désactivées si vide).
# Politique Acreed : laisser vide. L'IA tourne en local sur la VM client
# (chantier RAG + LLM local en cours, dispo Q3 2026). Voir docs/DEPLOYMENT.md.
ANTHROPIC_API_KEY=
