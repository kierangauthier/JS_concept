# ─── Base ─────────────────────────────────────────────
# Environnement d'exécution
NODE_ENV=production
# Port d'écoute de l'API
PORT=3000

# ─── Base de données ─────────────────────────────────
# URL de connexion PostgreSQL complète
DATABASE_URL=postgresql://user:password@host:5432/concept_manager?schema=public

# ─── Authentification ─────────────────────────────────
# OBLIGATOIRE — min 32 caractères, générer avec : openssl rand -base64 48
JWT_SECRET=
# Durée de validité du token d'accès (ex: 15m, 1h, 8h)
JWT_EXPIRY=15m
# Durée de validité du refresh token en jours
REFRESH_TOKEN_EXPIRY_DAYS=7

# ─── CORS ─────────────────────────────────────────────
# Origines autorisées, séparées par des virgules si multiples
CORS_ORIGINS=https://app.example.com

# ─── MinIO / S3 (stockage fichiers) ──────────────────
# Nom d'hôte du serveur MinIO
MINIO_ENDPOINT=minio
# Port du serveur MinIO
MINIO_PORT=9000
# Clé d'accès MinIO — ne pas laisser les valeurs par défaut en production
MINIO_ACCESS_KEY=
# Clé secrète MinIO — ne pas laisser les valeurs par défaut en production
MINIO_SECRET_KEY=
# Bucket principal pour les fichiers de chantier
MINIO_BUCKET=concept-files
# Bucket pour les documents RH
MINIO_HR_BUCKET=hr-documents

# ─── Email / SMTP (optionnel) ────────────────────────
# Serveur SMTP — laisser vide pour désactiver l'envoi d'emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Adresse d'expédition par défaut
SMTP_FROM=noreply@concept-manager.fr
